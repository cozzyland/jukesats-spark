{
  "expo": {
    "name": "Jukesats Spark",
    "slug": "jukesats-spark",
    "version": "1.0.0",
    "scheme": "jukesats",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jukesats.spark",
      "associatedDomains": [
        "applinks:cozzyland.net"
      ],
      "infoPlist": {
        "NFCReaderUsageDescription": "Jukesats uses NFC to detect tap points at cafes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jukesats.spark",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cozzyland.net",
              "pathPrefix": "/tap"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Jukesats needs your camera to scan QR codes for sending sats."
        }
      ]
    ]
  }
}
