# Jukesats Server Configuration

# Hot wallet mnemonic (REQUIRED)
# Generate one with: node -e "console.log(require('bip39').generateMnemonic())"
# Or let SparkWallet generate one and save the output
HOT_WALLET_MNEMONIC=your twelve word mnemonic phrase here

# Server port
PORT=3001

# Reward amount per tap (in sats)
DEFAULT_REWARD_SATS=330

# Cooldown between taps at same venue (in ms)
TAP_COOLDOWN_MS=60000

# Admin auth token (REQUIRED in production)
ADMIN_TOKEN=

# Allowed venue IDs (comma-separated)
ALLOWED_VENUES=test-venue-001

# Daily spend cap in sats (0 = unlimited)
DAILY_SPEND_CAP_SATS=100000

# Max taps per IP per hour
IP_RATE_LIMIT_MAX=10

# SQLite database path
DB_PATH=./data/jukesats.db

# CORS allowed origins (comma-separated)
CORS_ORIGIN=https://cozzyland.net

# Enable /simulate-tap endpoint (set to "true" only in development)
ENABLE_SIMULATE_TAP=false
